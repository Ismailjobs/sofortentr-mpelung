# ─── Kontaktformular ───
# Standard: Browser → gleiche Origin `/api/contact` → Next proxied weiter (siehe src/app/api/contact/route.ts).

# Wo Next serverseitig die Contact-API erreicht (lokal Express auf 4000)
# CONTACT_API_INTERNAL_URL=http://127.0.0.1:4000/api/contact

# Nur nötig, wenn der Browser DIREKT die API anspricht (anderer Host/Port als die Webseite):
# NEXT_PUBLIC_CONTACT_API_URL=https://api.example.com/api/contact

# Docker Compose „web → api“ Containername:
# CONTACT_API_INTERNAL_URL=http://api:4000/api/contact

# Brevo etc. → shared/contact/mail-config.ts
# reCAPTCHA Site → src/config/recaptcha.ts · Secret → shared/contact/mail-config.ts

# Optional: NEXT_DEV_ALLOWED_ORIGINS=…

# Canonical origin for JSON-LD and metadata (absolute URLs)
# NEXT_PUBLIC_SITE_URL=https://sofortentrumpelung.at
#
# Programmatic SEO: 23 Bezirks-Landings unter /entruempelung-wien-{PLZ} (siehe src/data/vienna-districts.ts)
#
# robots.txt liegt unter public/robots.txt — Sitemap-URL bei anderer Domain dort anpassen.
